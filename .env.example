# Copy this file to .env and fill in your own Supabase project values.
# Find both of these in your Supabase project: Settings -> API

# Project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Project API keys -> anon / public key
# This key is safe to expose in frontend code — Row Level Security
# policies (see supabase/rls_policies.sql) are what actually protect the data.
VITE_SUPABASE_ANON_KEY=
